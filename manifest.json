{
"manifest_version": 3,
"name": "Jable Collect",
"version": "1.0.1",
"description": "抓取、整理和浏览 Jable 收藏与稍后观看数据",
"permissions": [
  "storage",
  "activeTab",
  "scripting",
  "tabs"
],
"host_permissions": [
  "https://jable.tv/*",
  "https://missav.ws/*"
],
"background": {
  "service_worker": "background.js"
},
"content_scripts": [
  {
    "matches": ["https://jable.tv/my/favourites/*"],
    "js": ["content.js"]
  },
  {
    "matches": ["https://jable.tv/videos/*"],
    "js": ["content-jable-detail.js"],
    "run_at": "document_start"
  },
  {
    "matches": [
      "https://missav.ws/saved*",
      "https://missav.ws/*/saved*",
      "https://missav.ai/saved*",
      "https://missav.ai/*/saved*",
      "https://missav.live/saved*",
      "https://missav.live/*/saved*"
    ],
    "js": ["content-missav.js"]
  }
],
"web_accessible_resources": [
  {
    "resources": ["content-jable-detail-hook.js"],
    "matches": ["https://jable.tv/*"]
  }
],
"action": {
  "default_popup": "popup.html",
  "default_title": "Jable Collect"
},
"options_page": "options.html"
}
